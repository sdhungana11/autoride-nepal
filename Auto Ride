<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>AutoRide Nepal | Car Rental Service</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
    }

    header {
      background: #000;
      padding: 15px;
      text-align: center;
    }

    header img {
      max-width: 280px;
    }

    nav {
      background: #111;
      padding: 10px;
      text-align: center;
    }

    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }

    .hero {
      background: url('https://images.unsplash.com/photo-1503376780353-7e6692767b70') no-repeat center/cover;
      color: white;
      padding: 100px 20px;
      text-align: center;
    }

    .hero img {
      max-width: 350px;
      margin-bottom: 20px;
    }

    .btn {
      background: #fca311;
      color: black;
      padding: 12px 20px;
      text-decoration: none;
      border-radius: 5px;
      display: inline-block;
      margin-top: 10px;
      font-weight: bold;
    }

    .section {
      padding: 50px 20px;
      max-width: 1100px;
      margin: auto;
    }

    .services, .fleet {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }

    .card {
      flex: 1;
      min-width: 250px;
      background: #f1f1f1;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
    }

    .fleet img {
      width: 100%;
      border-radius: 8px;
    }

    form input, form textarea {
      width: 100%;
      padding: 10px;
      margin: 8px 0;
      border-radius: 5px;
      border: 1px solid #ccc;
    }

    footer {
      background: #000;
      color: white;
      text-align: center;
      padding: 15px;
    }

    .whatsapp {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background: #25D366;
      color: white;
      padding: 15px;
      border-radius: 50%;
      font-size: 20px;
      text-decoration: none;
    }
  </style>
</head>

<body>

<header>
  <img src="logo.png" alt="AutoRide Nepal Logo">
</header>

<nav>
  <a href="#about">About</a>
  <a href="#services">Services</a>
  <a href="#fleet">Fleet</a>
  <a href="#contact">Contact</a>
</nav>

<section class="hero">
  <img src="logo.png" alt="AutoRide Nepal">
  <h1>Drive Anywhere in Nepal</h1>
  <p>Reliable, affordable, and comfortable car rental services</p>
  <a href="#contact" class="btn">Book Now</a>
</section>

<section id="about" class="section">
  <h2>About Us</h2>
  <p>
    AutoRide Nepal provides professional car rental services across Nepal.
    We offer safe, comfortable, and affordable rides with experienced drivers.
  </p>
</section>

<section id="services" class="section">
  <h2>Our Services</h2>
  <div class="services">
    <div class="card">
      <h3>City Rides</h3>
      <p>Kathmandu, Pokhara, Chitwan and more.</p>
    </div>

    <div class="card">
      <h3>Tour Packages</h3>
      <p>Explore Nepal with our vehicles.</p>
    </div>

    <div class="card">
      <h3>Airport Pickup</h3>
      <p>Fast and reliable service.</p>
    </div>
  </div>
</section>

<section id="fleet" class="section">
  <h2>Our Fleet</h2>
  <div class="fleet">
    <div class="card">
      <img src="https://images.unsplash.com/photo-1549921296-3a6b6f1b4f82">
      <h3>Sedan</h3>
    </div>

    <div class="card">
      <img src="https://images.unsplash.com/photo-1511919884226-fd3cad34687c">
      <h3>SUV</h3>
    </div>

    <div class="card">
      <img src="https://images.unsplash.com/photo-1502877338535-766e1452684a">
      <h3>Jeep</h3>
    </div>
  </div>
</section>

<section id="contact" class="section">
  <h2>Book Your Ride</h2>

  <form onsubmit="sendWhatsApp(); return false;">
    <input type="text" id="name" placeholder="Your Name" required>
    <input type="text" id="pickup" placeholder="Pickup Location" required>
    <input type="date" id="date" required>
    <textarea id="message" placeholder="Additional details"></textarea>
    <button class="btn" type="submit">Send Booking via WhatsApp</button>
  </form>

  <h3>Contact Info</h3>
  <p>📞 +977-9855054934</p>
  <p>📧 basantadevkota9874@gmail.com</p>
  <p>📍 Chitwan, Nepal</p>
</section>

<a class="whatsapp" href="https://wa.me/9779855054934" target="_blank">💬</a>

<footer>
  <p>© 2026 AutoRide Nepal. All rights reserved.</p>
</footer>

<script>
function sendWhatsApp() {
  let name = document.getElementById("name").value;
  let pickup = document.getElementById("pickup").value;
  let date = document.getElementById("date").value;
  let message = document.getElementById("message").value;

  let url = "https://wa.me/9779855054934?text="
    + "Booking Request:%0A"
    + "Name: " + name + "%0A"
    + "Pickup: " + pickup + "%0A"
    + "Date: " + date + "%0A"
    + "Details: " + message;

  window.open(url, "_blank");
}
</script>

</body>
</html>
